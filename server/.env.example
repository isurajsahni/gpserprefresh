MONGODB_URI=mongodb://127.0.0.1:27017/gpsfdk_erp
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d
PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Cloudinary (server-side only — never expose on frontend)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email — SMTP (Nodemailer). Sends new-user credentials.
# Resend SMTP: host=smtp.resend.com, user=resend, pass=<your Resend API key>, port=465.
# EMAIL_FROM must use a domain verified in Resend (or onboarding@resend.dev for testing).
# Without these, emails are logged to the server console (dev fallback).
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_USER=resend
EMAIL_PASS=your_resend_api_key
EMAIL_FROM=contact@yourdomain.com
